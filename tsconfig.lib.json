{
  "compilerOptions": {
    "target": "ES2023",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2023"],
    "types": ["@citizenfx/server", "node"],
    "strict": true,
    "declaration": true,
    "sourceMap": false,
    "outDir": "./lib",
    "rootDir": "./lib",
    "allowJs": false,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules"]
}
